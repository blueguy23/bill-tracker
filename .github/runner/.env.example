# GitHub Personal Access Token
# Needs 'repo' scope (used to generate runner registration/removal tokens on startup)
# Generate at: GitHub > Settings > Developer settings > Personal access tokens > Tokens (classic)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Runner names are set per-service in docker-compose.yml (ci-runner-1, ci-runner-2).
# Do NOT set RUNNER_NAME here — it will be overridden by the compose environment.

# Repository targeting (defaults in docker-compose.yml, override here if needed)
# REPO_OWNER=blueguy23
# REPO_NAME=bill-tracker

# GID of the docker socket on the host — get with: stat -c '%g' /var/run/docker.sock
# On this machine it's 1001; only change if yours differs
DOCKER_GID=1001

# Docker Hub credentials (optional — prevents anonymous pull rate limit: 100/6hr per IP)
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# Disk watcher — prune Docker artifacts when free disk drops below this threshold
PRUNE_THRESHOLD_GB=10

# CPU cap per runner container — each runner gets this many CPUs
RUNNER_CPUS=3.0
