# GitHub Personal Access Token
# Needs 'repo' scope (used to generate runner registration/removal tokens on startup)
# Generate at: GitHub > Settings > Developer settings > Personal access tokens > Tokens (classic)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Runner display name shown in GitHub > repo Settings > Actions > Runners
RUNNER_NAME=ci-docker

# GID of the docker socket on the host — get with: stat -c '%g' /var/run/docker.sock
# On this machine it's 1001; only change if yours differs
DOCKER_GID=1001
